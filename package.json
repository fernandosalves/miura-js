{
    "name": "@miurajs",
    "version": "0.3.2",
    "description": "miura is a framework for building web components.",
    "private": true,
    "type": "module",
    "workspaces": [
        "packages/*"
    ],
    "scripts": {
        "dev": "vite",
        "build": "tsc && vite build",
        "preview": "vite preview",
        "start": "storybook dev -p 6006",
        "start:dev": "vite --port 3000",
        "build-storybook": "storybook build",
        "test": "vitest run"
    },
    "devDependencies": {
        "@playwright/test": "^1.53.0",
        "@storybook/addon-essentials": "^8.1.6",
        "@storybook/web-components-vite": "^8.1.6",
        "@types/node": "^24.0.1",
        "@vitejs/plugin-react": "^4.5.2",
        "jsdom": "^26.1.0",
        "lerna": "^8.1.2",
        "storybook": "^8.1.6",
        "typescript": "^5.4.5",
        "vite": "^5.2.11",
        "vitest": "^3.2.3"
    },
    "dependencies": {
        "@miurajs/miura": "^2.4.22",
        "@storybook/web-components": "8.6.18",
        "acorn-walk": "^8.3.5"
    }
}