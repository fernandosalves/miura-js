{
    "extends": "../../tsconfig.json",
    "compilerOptions": {
        "outDir": "dist",
        "composite": true,
        "baseUrl": ".",
        "paths": {
            "@miurajs/miura-element": ["../miura-element/index.ts"],
            "@miurajs/miura-render": ["../miura-render/index.ts"],
            "@miurajs/miura-debugger": ["../miura-debugger/index.ts"]
        }
    },
    "include": [
        "index.ts",
        "src/**/*"
    ],
    "exclude": [
        "node_modules",
        "dist",
        "stories"
    ],
    "references": [
        {
            "path": "../miura-element"
        }
    ]
}
