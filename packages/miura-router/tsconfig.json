{
    "extends": "../../tsconfig.json",
    "compilerOptions": {
        "outDir": "dist",
        "rootDir": ".",
        "composite": true,
        "baseUrl": ".",
        "paths": {
            "@miura/miura-debugger": ["../miura-debugger/index.ts"],
            "@miura/miura-router":   ["./index.ts"]
        }
    },
    "include": [
        "src/**/*",
        "index.ts"
    ],
    "exclude": [
        "node_modules",
        "stories/**/*",
        "dist/**/*"
    ],
    "references": [
        {
            "path": "../miura-debugger"
        }
    ]
}