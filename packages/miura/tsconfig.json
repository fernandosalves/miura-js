{
    "extends": "../../tsconfig.json",
    "compilerOptions": {
        "outDir": "dist",
        "rootDir": "./src",
        "composite": true,
        "baseUrl": ".",
        "paths": {
            "@miurajs/miura-element": [
                "../miura-element/index.ts"
            ],
            "@miurajs/miura-data-flow": [
                "../miura-data-flow/index.ts"
            ],
            "@miurajs/miura-framework": [
                "../miura-framework/src/index.ts"
            ],
            "@miurajs/miura-render": [
                "../miura-render/index.ts"
            ],
            "@miurajs/miura-router": [
                "../miura-router/index.ts"
            ],
            "@miurajs/miura-debugger": [
                "../miura-debugger/index.ts"
            ],
            "@miurajs/miura-security": [
                "../miura-security/index.ts"
            ],
            "@miurajs/miura-ui": [
                "../miura-ui/index.ts"
            ]
        }
    },
    "include": [
        "src/**/*"
    ],
    "exclude": [
        "node_modules"
    ],
    "references": [
        {
            "path": "../miura-data-flow"
        },
        {
            "path": "../miura-element"
        },
        {
            "path": "../miura-debugger"
        },
        {
            "path": "../miura-framework"
        },
        {
            "path": "../miura-render"
        },
        {
            "path": "../miura-router"
        },
        {
            "path": "../miura-security"
        },
        {
            "path": "../miura-ui"
        }
    ]
}