{
  "name": "miura",
  "version": "1.0.0-alpha.1",
  "description": "The main package for the miura framework, bundling all core modules.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "vite build",
    "build:tsc": "tsc",
    "dev": "vite build --watch",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "web-components",
    "framework",
    "javascript",
    "typescript"
  ],
  "author": "Fernando Alves",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fernandosalves/miura-js.git"
  },
  "bugs": {
    "url": "https://github.com/fernandosalves/miura-js/issues"
  },
  "homepage": "https://github.com/fernandosalves/miura-js#readme",
  "dependencies": {
    "@miura/miura-data-flow": "workspace:*",
    "@miura/miura-element": "workspace:*",
    "@miura/miura-framework": "workspace:*",
    "@miura/miura-render": "workspace:*",
    "@miura/miura-router": "workspace:*",
    "@miura/miura-debugger": "workspace:*",
    "@miura/miura-security": "workspace:*",
    "@miura/miura-ui": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.4.5"
  }
}
