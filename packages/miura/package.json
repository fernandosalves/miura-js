{
  "name": "@miurajs/miura",
  "version": "2.0.0",
  "description": "The main package for the miura framework, bundling all core modules.",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "files": ["src"],
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "scripts": {
    "build": "echo 'No build needed - using source files'",
    "build:tsc": "echo 'No build needed - using source files'",
    "dev": "echo 'No dev needed - using source files'",
    "prepublishOnly": "echo 'Publishing source files'"
  },
  "keywords": [
    "web-components",
    "framework",
    "javascript",
    "typescript"
  ],
  "author": "Fernando Alves",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fernandosalves/miura-js.git"
  },
  "bugs": {
    "url": "https://github.com/fernandosalves/miura-js/issues"
  },
  "homepage": "https://github.com/fernandosalves/miura-js#readme",
  "dependencies": {
    "@miurajs/miura-data-flow": "^0.1.2",
    "@miurajs/miura-element": "^0.1.2",
    "@miurajs/miura-framework": "^0.1.5",
    "@miurajs/miura-render": "^0.2.0",
    "@miurajs/miura-router": "^0.1.2",
    "@miurajs/miura-debugger": "^0.2.0",
    "@miurajs/miura-security": "^1.0.2",
    "@miurajs/miura-ui": "^0.1.1"
  },
  "devDependencies": {
    "typescript": "^5.4.5"
  }
