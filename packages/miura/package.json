{
    "name": "@miurajs/miura",
    "version": "2.5.0",
    "description": "The main package for the miura framework, bundling all core modules.",
    "type": "module",
    "main": "./dist/index.js",
    "types": "./src/index.ts",
    "files": [
        "dist",
        "src/index.ts"
    ],
    "exports": {
        ".": {
            "types": "./src/index.ts",
            "import": "./dist/index.js"
        }
    },
    "scripts": {
        "build": "tsc -b",
        "build:tsc": "tsc -p tsconfig.json",
        "dev": "tsc -w -p tsconfig.json",
        "prepublishOnly": "npm run build"
    },
    "keywords": [
        "web-components",
        "framework",
        "javascript",
        "typescript"
    ],
    "author": "Fernando Alves",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/fernandosalves/miura-js.git"
    },
    "bugs": {
        "url": "https://github.com/fernandosalves/miura-js/issues"
    },
    "homepage": "https://github.com/fernandosalves/miura-js#readme",
    "dependencies": {
        "@miurajs/miura-data-flow": "^0.4.0",
        "@miurajs/miura-element": "^0.4.0",
        "@miurajs/miura-framework": "^0.4.0",
        "@miurajs/miura-render": "^0.4.0",
        "@miurajs/miura-router": "^0.4.0",
        "@miurajs/miura-debugger": "^0.4.0",
        "@miurajs/miura-security": "^1.0.2",
        "@miurajs/miura-ui": "^0.2.4"
    },
    "devDependencies": {
        "typescript": "^5.4.5"
    }
}