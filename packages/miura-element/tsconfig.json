{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "outDir": "dist",
    "rootDir": ".",
    "composite": true,
    "baseUrl": ".",
    "paths": {
      "@miurajs/miura-render":  ["../miura-render/index.ts"],
      "@miurajs/miura-debugger": ["../miura-debugger/index.ts"],
      "@miurajs/miura-element": ["./index.ts"]
    }
  },
  "include": ["index.ts", "server.ts", "src/**/*"],
  "exclude": ["node_modules", "stories/**/*", "dist/**/*"],
  "references": [
    { "path": "../miura-render" }
  ]
}
