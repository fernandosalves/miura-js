{
    "extends": "../../tsconfig.json",
    "compilerOptions": {
        "outDir": "dist",
        "rootDir": ".",
        "composite": true,
        "baseUrl": ".",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "paths": {
            "@miurajs/miura-element": ["../miura-element/index.ts"],
            "@miurajs/miura-vite":    ["./index.ts"]
        }
    },
    "include": [
        "src/**/*",
        "index.ts",
        "test/**/*"
    ],
    "references": [
        { "path": "../miura-element" }
    ],
    "exclude": [
        "node_modules"
    ]
}
